# Oracle DBA Toolkit — Per-Database Configuration Template
# Copy this file to config/db_<YOURSID>.env and fill in values.
# Example: config/db_PRODDB.env, config/db_TRNG.env, config/db_CONBI16.env
#
# NEVER commit config/db_*.env files — they are in .gitignore.
#
# One file per database. lib/oracle_connect.sh loads config/db_${ORACLE_SID}.env
# automatically when ORACLE_SID is set before sourcing the lib.
#
# If this file does not exist for a given SID, ORACLE_HOME will be derived
# from /etc/oratab automatically as a fallback.

# Database identifier — must match the filename (db_<SID>.env)
ORACLE_SID=EXAMPLE

# Oracle Home for this database
ORACLE_HOME=/u01/app/oracle/product/19c/db_1

# Database type
# Set IS_CDB=YES for Container Databases (CDB), NO for standalone (non-CDB)
IS_CDB=NO

# PDB name — only applies when IS_CDB=YES
# Set to the PDB name to run queries in that PDB context via oracle_run_sql().
# Leave commented out to connect to CDB$ROOT (for instance-level queries).
# ORACLE_PDB=MYPDB

# Connection credentials (only needed if not using Oracle Wallet)
# DBA_USER=system
# DBA_PASS=changeme

# Oracle Wallet location (preferred over plaintext credentials)
# ORACLE_WALLET_LOC=/etc/oracle/wallet/${ORACLE_SID}
