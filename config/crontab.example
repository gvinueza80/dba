# Oracle DBA Toolkit — Reference Crontab
# Server : db-analytics-01
# User   : oracle
#
# HOW TO APPLY:
#   crontab -e          # edit live crontab
#   crontab -l          # view live crontab
#
# Copy the entries below into crontab -e.
# TOOLKIT_ROOT = /u01/app/oracle/scripts/oracle-dba-toolkit
#
# Note: scripts manage their own logs via lib/logger.sh.
# The 2>&1 redirect below only captures startup errors (e.g. missing config).

# ─── Environment ──────────────────────────────────────────────────────────────
SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin
ORACLE_BASE=/u01/app/oracle

# ─── Wave 2 — Daily Health Check ─────────────────────────────────────────────
# Run every day at 07:00 (before business hours)

0 7 * * * /u01/app/oracle/scripts/oracle-dba-toolkit/wave2-health-monitoring/health-check/daily_health_check.sh CONBI8  2>&1
0 7 * * * /u01/app/oracle/scripts/oracle-dba-toolkit/wave2-health-monitoring/health-check/daily_health_check.sh CONBI16 2>&1

# ─── Wave 2 — Monitoring ──────────────────────────────────────────────────────
# Run every 15 min during business hours (08:00–17:00), Mon–Fri

*/15 08-17 * * 1-5 /u01/app/oracle/scripts/oracle-dba-toolkit/wave2-stability/monitoring/oracle_monitor.sh CONBI8  2>&1
*/15 08-17 * * 1-5 /u01/app/oracle/scripts/oracle-dba-toolkit/wave2-stability/monitoring/oracle_monitor.sh CONBI16 2>&1

# ─── Wave 2 — RMAN Backup ─────────────────────────────────────────────────────
# Level 0 (full)        — Friday at 23:45
# Level 1 (incremental) — Monday–Thursday at 23:45

45 23 * * 5   /u01/app/oracle/scripts/oracle-dba-toolkit/wave2-stability/backup/rman_backup.sh CONBI8  0 2>&1
45 23 * * 5   /u01/app/oracle/scripts/oracle-dba-toolkit/wave2-stability/backup/rman_backup.sh CONBI16 0 2>&1

45 23 * * 1-4 /u01/app/oracle/scripts/oracle-dba-toolkit/wave2-stability/backup/rman_backup.sh CONBI8  1 2>&1
45 23 * * 1-4 /u01/app/oracle/scripts/oracle-dba-toolkit/wave2-stability/backup/rman_backup.sh CONBI16 1 2>&1

# ─── Wave 6 — License Compliance Audit ───────────────────────────────────────
# Run on the 1st of each month at 08:00

0 8 1 * * /u01/app/oracle/scripts/oracle-dba-toolkit/wave6-governance/licensing/feature-usage-audit.sh CONBI8  2>&1
0 8 1 * * /u01/app/oracle/scripts/oracle-dba-toolkit/wave6-governance/licensing/feature-usage-audit.sh CONBI16 2>&1
